<UserControl x:Class="RetroBar.Controls.Clock"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        MouseLeftButtonDown="Clock_OnMouseLeftButtonDown"
        MouseDoubleClick="Clock_OnMouseDoubleClick"
        Loaded="UserControl_Loaded"
        Unloaded="UserControl_Unloaded"
        ToolTipService.InitialShowDelay="0"
        ToolTipService.BetweenShowDelay="0">
        <StackPanel VerticalAlignment="Center" TextOptions.TextFormattingMode="Display">
            <TextBlock Text="{Binding Path=Now, StringFormat=t, Mode=OneWay}" 
                    HorizontalAlignment="Center"
                    Foreground="White"
                    FontFamily="Tahoma" 
                    FontSize="12"
                    Style="{DynamicResource ClockText}" />
            <TextBlock Text="{Binding Path=Now, StringFormat={}{0:M/dd/yy}, Mode=OneWay}" 
                    HorizontalAlignment="Center"
                    Foreground="White"
                    FontFamily="Tahoma"
                    FontSize="12"
                    Margin="0,-2,0,0"
                    Style="{DynamicResource ClockText}" />
        </StackPanel>
    <UserControl.ToolTip>
        <ToolTip FontSize="12">
            <TextBlock Text="{Binding Path=Now, StringFormat=D, Mode=OneWay}" Name="ClockTip" />
        </ToolTip>
    </UserControl.ToolTip>
</UserControl>